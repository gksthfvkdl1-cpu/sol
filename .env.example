# --- 로컬 개발: 이 파일을 복사해 .env 로 저장한 뒤 VITE_SUPABASE_ANON_KEY 만 채우세요 ---
#   copy .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# anon 키: Supabase 대시보드 → Project Settings → API → Project API keys → anon public
# (GitHub Actions 에는 secrets.VITE_SUPABASE_ANON_KEY 로 동일 값이 들어가 있음)

# 운영(GitHub Pages)과 동일한 프로젝트
VITE_SUPABASE_URL=https://bvnlwpjjzptarpbwkeqn.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon_공개키를_여기에

# 로컬에서는 경로를 기본(/)로 두고 http://localhost:5173/ 로 접속하세요.
# 이 줄을 쓰면 http://localhost:5173/sol/ 로 열어야 합니다.
# VITE_BASE_PATH=/sol/

# 로그인: Postgres RPC(app_login 등) + public.profiles.password_hash
# 스키마: supabase/migrations/001_initial.sql 이후 005_postgres_session_auth.sql

# (선택) 빌드 시 자동 로그인 — 비밀번호는 번들에 포함되므로 공개 저장소에 넣지 마세요.
# VITE_AUTO_ADMIN_ID=
# VITE_AUTO_ADMIN_PASSWORD=
# VITE_INITIAL_NAV=admin

# 관리자 초상화 — Cloudinary Unsigned preset (로컬 .env 에도 운영과 동일하게 두면 됨)
VITE_CLOUDINARY_CLOUD_NAME=djon3nvjm
VITE_CLOUDINARY_UPLOAD_PRESET=seven_Sol

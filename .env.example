# ========== 프론트 (Vite / GitHub Actions 빌드) ==========
# 비우면 로컬에서만 `/api` → Vite 프록시. GitHub Pages 배포 시에는 반드시 채워야 합니다.
#
# VITE_API_URL = API 베이스 origin (슬래시 없음). CI 는 pages.yml 값을 사용합니다.
#   · Supabase 대시보드의 "Publishable key" / "API Key" 값을 넣는 것이 아닙니다.
#   · Supabase 프로젝트 URL(https://xxxx.supabase.co)만으로도 이 앱의 /api/* 는 동작하지 않습니다.
#   · CI(GitHub Actions) 빌드는 .github/workflows/pages.yml 의 VITE_API_URL 을 사용합니다.
#   · 로컬 개발은 비우면 Vite 프록시(/api) 또는 여기에 백엔드 origin 을 넣습니다.
#
VITE_API_URL=

# GitHub Pages: https://gksthfvkdl1-cpu.github.io/sol/
VITE_BASE_PATH=/sol/

# ========== Supabase (이 프로젝트 기본 구조에서는 미사용) ==========
# DB를 Supabase PostgreSQL 로 두려면 "배포한 Node 서버" 쪽 환경변수 DATABASE_URL 에
# Supabase 연결 문자열을 넣는 방식이 일반적입니다. 프론트의 VITE_* 에 키를 넣는 단계가 아닙니다.
# Publishable 키를 채팅/공개 저장소에 올리지 마세요. 노출 시 Supabase 대시보드에서 키를 재발급하세요.

# ---- API 서버 (server/server.mjs, Render 등) ----
# JWT_SECRET=긴_랜덤_문자열
# PORT=3001
#
# DATABASE_URL=postgresql://...  (있으면 PostgreSQL / Render Postgres 사용, 데이터 영구 저장)
#   · 비우면 로컬은 SQLite(server/data/app.db). DB_PATH 로 파일 경로 지정 가능.
#   · Render에서 Postgres를 Web Service에 연결하면 대시보드가 DATABASE_URL을 넣어 줍니다.

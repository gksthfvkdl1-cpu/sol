# --- Supabase (필수) ---
# 대시보드 → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...공개_키

# 아이디만 입력 시 내부 조합: {sanitize}@gmail.com (기본). @ 포함 시 전체를 이메일로 사용.
# 다른 도메인을 쓰려면:
# VITE_AUTH_EMAIL_DOMAIN=example.com

# GitHub Pages
VITE_BASE_PATH=/sol/

# GitHub Actions: Repository secrets → VITE_SUPABASE_ANON_KEY
# 서비스 롤 키·DB 비밀번호는 프론트/저장소에 넣지 마세요.
#
# DB 스키마: supabase/migrations/001_initial.sql 을 Supabase SQL Editor에서 한 번 실행.
# 관리자: Authentication에서 사용자 추가(예: admin@gmail.com — 아이디 admin 과 동일 규칙) 후
#   SQL: UPDATE public.profiles SET approved=true, is_admin=true, display_name='관리자' WHERE username='admin';

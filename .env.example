# --- Supabase PostgREST (필수) ---
# 대시보드 → Project Settings → API (anon 공개 키만 사용)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...공개_키

# 로그인은 Supabase Auth 를 쓰지 않고, Postgres RPC(app_login 등) + public.profiles.password_hash 입니다.
# 스키마: supabase/migrations/001_initial.sql 실행 후 반드시 005_postgres_session_auth.sql 을 실행하세요.

# GitHub Pages
VITE_BASE_PATH=/sol/

# (선택) 빌드 시 자동 로그인 — 비밀번호는 번들에 포함되므로 공개 저장소에 넣지 마세요.
# VITE_AUTO_ADMIN_ID=gksthfvkdl
# VITE_AUTO_ADMIN_PASSWORD=
# VITE_INITIAL_NAV=admin

# GitHub Actions: secrets → VITE_SUPABASE_ANON_KEY
# 서비스 롤 키는 프론트에 넣지 마세요.

# --- Supabase (필수) ---
# 대시보드 → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...공개_키

# 아이디만 입력 시 내부 조합: {sanitize}@gmail.com (기본). @ 포함 시 전체를 이메일로 사용.
# 다른 도메인을 쓰려면:
# VITE_AUTH_EMAIL_DOMAIN=example.com
#
# 로그인 시 "이메일 인증이 완료되지 않았습니다" 가 나오면 Supabase → Authentication → Providers → Email
# 에서 Confirm email(이메일 확인)을 끄거나, Users에서 해당 사용자 이메일 확인을 처리하세요.

# GitHub Pages
VITE_BASE_PATH=/sol/

# 접속 즉시 관리자 계정으로 로그인 + 첫 화면을 회원가입 신청(admin)으로 (선택)
# 비밀번호는 Vite 번들에 포함되므로 공개 저장소에는 넣지 마세요. GitHub Actions는 Repository secrets 사용.
# VITE_AUTO_ADMIN_ID=gksthfvkdl
# VITE_AUTO_ADMIN_PASSWORD=
# VITE_INITIAL_NAV=admin

# GitHub Actions: Repository secrets → VITE_SUPABASE_ANON_KEY
# 서비스 롤 키·DB 비밀번호는 프론트/저장소에 넣지 마세요.
#
# DB 스키마: supabase/migrations/001_initial.sql 을 Supabase SQL Editor에서 한 번 실행.
# 이미 적용한 DB는 002~004 패치를 순서대로 실행하세요 (최소 004_auth_public_config.sql 권장).
#
# public.auth_public_config (단일 행 id=1): 관리자·가입 차단 규칙
#   admin_username_contains — 아이디에 이 문자열이 포함되면 관리자로 인식
#   admin_email_exact — 로그인 이메일이 이 값과 같으면 관리자
#   signup_forbid_username_contains — 회원가입 시 아이디에 포함되면 가입 불가
# 비밀번호 검증은 Supabase Auth(auth.users)가 담당합니다.
